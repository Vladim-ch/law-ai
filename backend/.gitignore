# Локальные артефакты backend (корневой .gitignore уже покрывает большинство,
# но оставляем этот файл для явности и на случай работы с backend/ как
# самостоятельным подпроектом).

node_modules/
dist/
*.tsbuildinfo

# Локальный .env внутри backend не используем — читаем корневой.
# Но на всякий случай, если кто-то создаст его по привычке:
.env
.env.*
!.env.example

# Логи и coverage.
logs/
*.log
coverage/
