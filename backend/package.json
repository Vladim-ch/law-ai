{
  "name": "@lawer/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Lawer backend — Fastify + TypeScript + Prisma",
  "type": "module",
  "engines": {
    "node": ">=20.6.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../.env dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json,md}\"",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^10.0.0",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "docx": "^9.6.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.1",
    "mammoth": "^1.12.0",
    "minio": "^8.0.7",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.17.0",
    "eslint": "^9.39.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
