# =============================================================================
# Lawer Frontend — .dockerignore
# =============================================================================
# Исключает из build-контекста файлы, не нужные для сборки образа.
# Применяется при `docker compose build frontend` (context: ./frontend).
# =============================================================================

# Артефакты сборки (пересоздаются внутри контейнера)
.next/
out/
*.tsbuildinfo

# Зависимости (устанавливаются через npm ci внутри контейнера)
node_modules/

# Git
.git/
.gitignore
.gitattributes

# Переменные окружения (секреты — не копируем в образ)
.env
.env.*

# IDE и редакторы
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# Логи
logs/
*.log
npm-debug.log*

# Тесты и покрытие
coverage/
.nyc_output/
.vitest-cache/
test-results/

# Документация (не нужна в рантайм-образе)
README.md
*.md

# Конфиги, не нужные в образе
.prettierrc.json
eslint.config.js
