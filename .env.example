# =========================================
# Lawer — шаблон переменных окружения
#
# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env
#
# ВАЖНО: реальные секреты (пароли, API-ключи, JWT) ни при каких обстоятельствах
# не коммитятся в git. .env находится в .gitignore.
# =========================================

# ===== Общие =====
# Таймзона, которую наследуют ВСЕ контейнеры (postgres, redis, minio, minio-init
# и в будущем backend/frontend). Для юридического ПО единая TZ критична:
# от неё зависят сроки исковой давности, процессуальные дедлайны, метки в
# аудит-логах и корректность триггеров в БД. Irkutsk = UTC+8, без перехода
# на летнее время.
TZ=Asia/Irkutsk

# ===== Backend =====
NODE_ENV=development
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0

# ===== PostgreSQL (с расширением pgvector) =====
POSTGRES_USER=lawer
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=lawer
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# DATABASE_URL используется Prisma; должен совпадать с параметрами выше
DATABASE_URL=postgresql://lawer:change_me_in_prod@postgres:5432/lawer

# ===== Redis (BullMQ очереди + кэш) =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ===== MinIO (S3-совместимое хранилище загруженных документов) =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_prod
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_DOCUMENTS=lawer-documents
MINIO_USE_SSL=false

# ===== JWT / Аутентификация =====
# В продакшене — длинная случайная строка (минимум 32 байта энтропии):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=change_me_in_prod_use_random_32_byte_string
JWT_EXPIRES_IN=7d

# ===== LLM (Ollama / OpenAI-совместимый API) =====
# Ollama поднимается в Docker Compose как сервис ollama.
# API совместим с OpenAI SDK — можно переключиться на OpenAI/Claude/DeepSeek,
# изменив LLM_BASE_URL и LLM_API_KEY.
#
# Для скачивания модели при первом запуске:
#   docker compose --profile init up ollama-init
#
# Модель по умолчанию: qwen2.5:7b (работает на CPU, ~4.5GB RAM).
# На RTX 4090 (24GB VRAM): qwen2.5:14b или qwen2.5:32b.
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=qwen2.5:7b
# Для Ollama API key не требуется, но OpenAI SDK требует непустое значение.
# При переключении на OpenAI/Claude — вставить реальный ключ.
LLM_API_KEY=ollama

# ===== Эмбеддинги (RAG) =====
# Модель эмбеддингов для семантического поиска. nomic-embed-text — лёгкая,
# работает на CPU, хорошо с русским текстом (768 размерность).
# Скачивание: docker exec lawer-ollama ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text
# Размерность вектора. Должна совпадать с моделью и vector() в schema.prisma.
EMBEDDING_DIMENSIONS=768

# ===== Frontend =====
# URL бэкенда, видимый браузеру (переменные NEXT_PUBLIC_* попадают в bundle).
# Если тестируешь из локальной сети — замени localhost на IP сервера:
#   NEXT_PUBLIC_API_URL=http://192.168.x.x:4000
# ВАЖНО: после смены нужно пересобрать frontend (docker compose build frontend),
# т.к. NEXT_PUBLIC_* вшиваются в JS-bundle при сборке.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Lawer

# ===== Логирование =====
LOG_LEVEL=info

# ===== Загрузка файлов =====
# Максимальный размер загружаемого документа, в байтах. ТЗ: до 50 МБ
MAX_UPLOAD_SIZE=52428800
